# ============================================================
# Soft Landing — Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env — it contains secrets.
# ============================================================

# ------------------------------------------------------------
# Backend Server
# ------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=true
LOG_LEVEL=info

# ------------------------------------------------------------
# WebSocket
# ------------------------------------------------------------
WS_PORT=8001

# ------------------------------------------------------------
# Google Gemini
# ------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.0

# ------------------------------------------------------------
# Google Maps (used via Gemini Grounding)
# ------------------------------------------------------------
GOOGLE_MAPS_API_KEY=

# ------------------------------------------------------------
# Lufthansa Flight Ops API
# ------------------------------------------------------------
LH_API_CLIENT_ID=
LH_API_CLIENT_SECRET=
LH_API_BASE_URL=https://api.lufthansa.com/v1

# ------------------------------------------------------------
# Lufthansa MQTT (disruption events)
# Wire up last — use disruption simulator during development
# ------------------------------------------------------------
MQTT_BROKER_URL=
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=flight-ops/disruptions

# ------------------------------------------------------------
# Gate Agent Dashboard
# ------------------------------------------------------------
DASHBOARD_URL=http://localhost:3000

# ------------------------------------------------------------
# Passenger App
# ------------------------------------------------------------
PASSENGER_APP_URL=http://localhost:3001
