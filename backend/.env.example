# ============================================================
# Soft Landing — Backend Configuration
# ============================================================
# Copy to .env and fill in your values
# ============================================================

# Database (set automatically in docker-compose.prod.yml)
# DATABASE_URL=postgresql+asyncpg://softlanding:softlanding@localhost/softlanding

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.0

# Lufthansa Flight Ops API
LH_API_CLIENT_ID=
LH_API_CLIENT_SECRET=
LH_API_BASE_URL=https://api.lufthansa.com/v1
